# 服务器配置
PORT=3101
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRES_IN=7d

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pms
DB_USER=pms_user
DB_PASSWORD=your-db-password-here

# SQLite配置 (开发环境可选)
SQLITE_PATH=../database/pms.db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sentry错误追踪
SENTRY_DSN=

# WebSocket配置
WS_PORT=3102

# OTA渠道配置
# 携程 (Ctrip)
OTA_CTRIP_ENABLED=false
OTA_CTRIP_API_URL=https://api.ctrip.com
OTA_CTRIP_HOTEL_ID=your-hotel-id
OTA_CTRIP_API_KEY=your-api-key
OTA_CTRIP_API_SECRET=your-api-secret

# 美团 (Meituan)
OTA_MEITUAN_ENABLED=false
OTA_MEITUAN_API_URL=https://api.meituan.com
OTA_MEITUAN_HOTEL_ID=your-hotel-id
OTA_MEITUAN_APP_KEY=your-app-key
OTA_MEITUAN_APP_SECRET=your-app-secret

# Booking.com
OTA_BOOKING_ENABLED=false
OTA_BOOKING_API_URL=https://api.booking.com
OTA_BOOKING_HOTEL_ID=your-hotel-id
OTA_BOOKING_USERNAME=your-username
OTA_BOOKING_PASSWORD=your-password
