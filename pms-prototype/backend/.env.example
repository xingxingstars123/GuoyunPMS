# 服务器配置
PORT=3101
NODE_ENV=development

# JWT配置
JWT_SECRET=your-secret-key-here-please-change-in-production
JWT_EXPIRES_IN=7d

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pms
DB_USER=pms_user
DB_PASSWORD=your-db-password-here

# SQLite配置 (开发环境可选)
SQLITE_PATH=../database/pms.db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sentry错误追踪
SENTRY_DSN=

# WebSocket配置
WS_PORT=3102
